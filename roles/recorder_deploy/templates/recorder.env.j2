# Managed by Ansible (recorder_deploy). Do not edit on the host.
RECORDER_ADDR="{{ recorder_listen_address }}:{{ recorder_port }}"
RECORDER_DB_PATH="{{ recorder_data_dir }}/recorder.db"
RECORDER_DATA_DIR="{{ recorder_data_dir }}/objects"
RECORDER_PUBLIC_URL="{{ recorder_public_url }}"
{% if recorder_host_token | length > 0 %}
RECORDER_HOST_TOKEN="{{ recorder_host_token }}"
{% endif %}
RECORDER_LIVE_ROOM_PREFIX="{{ recorder_live_room_prefix }}"
{% if recorder_s3_endpoint | length > 0 %}
RECORDER_S3_ENDPOINT="{{ recorder_s3_endpoint }}"
RECORDER_S3_BUCKET="{{ recorder_s3_bucket }}"
RECORDER_S3_ACCESS_KEY="{{ recorder_s3_access_key }}"
RECORDER_S3_SECRET_KEY="{{ recorder_s3_secret_key }}"
RECORDER_S3_USE_SSL="{{ recorder_s3_use_ssl | bool | lower }}"
{% endif %}
{% if recorder_livekit_api_key | length > 0 %}
RECORDER_LIVEKIT_URL="{{ recorder_livekit_url }}"
RECORDER_LIVEKIT_API_KEY="{{ recorder_livekit_api_key }}"
RECORDER_LIVEKIT_API_SECRET="{{ recorder_livekit_api_secret }}"
{% endif %}
