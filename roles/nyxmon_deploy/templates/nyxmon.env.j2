# Nyxmon environment configuration
# Managed by Ansible - do not edit manually

# Django settings
DJANGO_SETTINGS_MODULE={{ nyxmon_django_settings_module }}
DJANGO_SECRET_KEY={{ nyxmon_django_secret_key }}
DJANGO_ALLOWED_HOSTS={{ nyxmon_django_allowed_hosts }}
DJANGO_CACHE_LOCATION={{ nyxmon_cache_dir }}
DJANGO_ADMIN_URL={{ nyxmon_django_admin_url }}
DJANGO_DEBUG={{ nyxmon_django_debug | lower }}

# Telegram settings
TELEGRAM_BOT_TOKEN={{ nyxmon_telegram_bot_token }}
TELEGRAM_CHAT_ID={{ nyxmon_telegram_chat_id }}
{% if nyxmon_opsgate_submit_base_url | trim | length > 0 and nyxmon_opsgate_submit_token | trim | length > 0 %}

# OpsGate producer integration (optional)
OPSGATE_SUBMIT_BASE_URL={{ nyxmon_opsgate_submit_base_url }}
OPSGATE_SUBMIT_TOKEN={{ nyxmon_opsgate_submit_token }}
OPSGATE_APPROVAL_BASE_URL={{ nyxmon_opsgate_approval_base_url }}
OPSGATE_TICKET_EXPIRES_SECONDS={{ nyxmon_opsgate_ticket_expires_seconds }}
OPSGATE_SUBMIT_TIMEOUT_SECONDS={{ nyxmon_opsgate_submit_timeout_seconds }}
OPSGATE_SUBMIT_INCLUDE_WARNINGS={{ nyxmon_opsgate_submit_include_warnings | lower }}
{% endif %}

# Application settings
APP_HOST={{ nyxmon_app_host }}
APP_PORT={{ nyxmon_app_port }}
