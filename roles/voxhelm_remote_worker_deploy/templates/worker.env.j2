DJANGO_SETTINGS_MODULE="config.settings"
# Dummy value for Django settings import only. The remote worker does not serve
# HTTP sessions or sign application tokens.
DJANGO_SECRET_KEY="voxhelm-remote-worker-local-settings"
VOXHELM_WORKER_BASE_URL={{ voxhelm_remote_worker_base_url | quote }}
VOXHELM_WORKER_ID={{ voxhelm_remote_worker_id | quote }}
VOXHELM_WORKER_TOKEN={{ voxhelm_remote_worker_token | quote }}
VOXHELM_ALLOWED_URL_HOSTS={{ (voxhelm_remote_worker_allowed_url_hosts | join(',')) | quote }}
VOXHELM_STT_BACKEND={{ voxhelm_remote_worker_stt_backend | quote }}
VOXHELM_STT_FALLBACK_BACKEND={{ voxhelm_remote_worker_stt_fallback_backend | quote }}
VOXHELM_MLX_MODEL={{ voxhelm_remote_worker_mlx_model | quote }}
VOXHELM_WHISPERCPP_MODEL={{ voxhelm_remote_worker_whispercpp_model | quote }}
VOXHELM_WHISPERCPP_BIN={{ voxhelm_remote_worker_whispercpp_bin | quote }}
VOXHELM_WHISPERCPP_PROCESSORS={{ voxhelm_remote_worker_whispercpp_processors | int }}
VOXHELM_WHISPERKIT_ENABLED={{ 'true' if voxhelm_remote_worker_whisperkit_enabled | bool else 'false' }}
VOXHELM_WHISPERKIT_BASE_URL={{ voxhelm_remote_worker_whisperkit_base_url | quote }}
VOXHELM_WHISPERKIT_MODEL={{ voxhelm_remote_worker_whisperkit_model | quote }}
VOXHELM_STT_DEBUG_LOGGING={{ 'true' if voxhelm_remote_worker_stt_debug_logging | bool else 'false' }}
VOXHELM_DIARIZATION_BACKEND={{ voxhelm_remote_worker_diarization_backend | quote }}
VOXHELM_PYANNOTE_MODEL={{ voxhelm_remote_worker_pyannote_model | quote }}
VOXHELM_PYANNOTE_DEVICE={{ voxhelm_remote_worker_pyannote_device | quote }}
VOXHELM_HUGGINGFACE_TOKEN={{ voxhelm_remote_worker_huggingface_token | quote }}
HF_TOKEN={{ voxhelm_remote_worker_huggingface_token | quote }}
VOXHELM_MODEL_CACHE_DIR={{ voxhelm_remote_worker_model_cache_dir | quote }}
VOXHELM_FFMPEG_BIN={{ voxhelm_remote_worker_ffmpeg_bin | quote }}
VOXHELM_ARTIFACT_BACKEND={{ voxhelm_remote_worker_artifact_backend | quote }}
VOXHELM_ARTIFACT_BUCKET={{ voxhelm_remote_worker_artifact_bucket | quote }}
VOXHELM_ARTIFACT_PREFIX={{ voxhelm_remote_worker_artifact_prefix | quote }}
VOXHELM_ARTIFACT_S3_ENDPOINT_URL={{ voxhelm_remote_worker_artifact_s3_endpoint_url | quote }}
VOXHELM_ARTIFACT_S3_REGION={{ voxhelm_remote_worker_artifact_s3_region | quote }}
VOXHELM_ARTIFACT_S3_ACCESS_KEY_ID={{ voxhelm_remote_worker_artifact_s3_access_key_id | quote }}
VOXHELM_ARTIFACT_S3_SECRET_ACCESS_KEY={{ voxhelm_remote_worker_artifact_s3_secret_access_key | quote }}
VOXHELM_ARTIFACT_S3_FORCE_PATH_STYLE={{ 'true' if voxhelm_remote_worker_artifact_s3_force_path_style | bool else 'false' }}
