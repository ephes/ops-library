# Managed by Ansible (delve_deploy). Do not edit on the host.
DELVE_ADDR="{{ delve_listen_address }}:{{ delve_port }}"
DELVE_DB_PATH="{{ delve_data_dir }}/delve.db"
DELVE_PUBLIC_URL="{{ delve_public_url }}"
DELVE_SESSION_SECRET="{{ delve_session_secret }}"
{% if delve_admin_emails | length > 0 %}
DELVE_ADMIN_EMAILS="{{ delve_admin_emails }}"
{% endif %}
{% if delve_dogfood_token | length > 0 %}
DELVE_DOGFOOD_TOKEN="{{ delve_dogfood_token }}"
{% endif %}
{% if delve_apple_client_id | length > 0 %}
DELVE_APPLE_CLIENT_ID="{{ delve_apple_client_id }}"
{% endif %}
{% if delve_storekit_root_certs_path | length > 0 %}
DELVE_STOREKIT_ROOT_CERTS="{{ delve_storekit_root_certs_path }}"
DELVE_STOREKIT_BUNDLE_ID="{{ delve_storekit_bundle_id }}"
DELVE_STOREKIT_PRODUCT_IDS="{{ delve_storekit_product_ids }}"
{% endif %}
DELVE_DISCOVERY_POLL_INTERVAL_SECONDS="{{ delve_discovery_poll_interval_seconds }}"
DELVE_DISCOVERY_POLL_JITTER_SECONDS="{{ delve_discovery_poll_jitter_seconds }}"
DELVE_DISCOVERY_EPISODE_TTL_SECONDS="{{ delve_discovery_episode_ttl_seconds }}"
DELVE_DISCOVERY_MAX_ITEMS_PER_FEED="{{ delve_discovery_max_items_per_feed }}"
DELVE_DISCOVERY_MAX_SOURCES_PER_RUN="{{ delve_discovery_max_sources_per_run }}"
{% if delve_env | length > 0 %}
DELVE_ENV="{{ delve_env }}"
{% endif %}
