#!/usr/bin/env python3
"""
Graphyard backup/restore runner for Echoport.

Service-owned same-host script:
- Backup: SQLite snapshot + native InfluxDB backup + config/system snapshot,
  archive upload to MinIO.
- Restore: download + checksum verify + safe extract + safety snapshot +
  ordered restore (InfluxDB -> SQLite -> config) + validation + rollback.
"""

import hashlib
import json
import math
import os
import shlex
import shutil
import subprocess
import sys
import tarfile
import tempfile
import time
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict, Optional
from urllib.error import URLError
from urllib.request import Request, urlopen

os.environ["PYTHONUNBUFFERED"] = "1"

# Shared configuration
MC_PATH = "{{ echoport_backup_mc_install_path }}"
MINIO_ALIAS = "{{ echoport_backup_minio_alias }}"
DEFAULT_BUCKET = "{{ echoport_backup_default_bucket }}"
TEMP_DIR = "{{ echoport_backup_temp_dir }}"

# Graphyard-specific configuration
SITE_ROOT = "{{ graphyard_echoport_backup_site_root }}"
DJANGO_DIR = "{{ graphyard_echoport_backup_django_dir }}"
VENV_PYTHON = "{{ graphyard_echoport_backup_venv_python }}"
MANAGE_PY = "{{ graphyard_echoport_backup_manage_py }}"
ENV_FILE = "{{ graphyard_echoport_backup_env_file }}"
DB_PATH = "{{ graphyard_echoport_backup_db_path }}"
WEB_SERVICE = "{{ graphyard_echoport_backup_web_service }}"
AGENT_SERVICE = "{{ graphyard_echoport_backup_agent_service }}"
WEB_UNIT = "{{ graphyard_echoport_backup_web_unit }}"
AGENT_UNIT = "{{ graphyard_echoport_backup_agent_unit }}"
GRAPHYARD_USER = "{{ graphyard_echoport_backup_system_user }}"

INFLUX_CONTAINER = "{{ graphyard_echoport_backup_influx_container }}"
INFLUX_DATA_DIR = "{{ graphyard_echoport_backup_influx_data_dir }}"
INFLUX_CONFIG_DIR = "{{ graphyard_echoport_backup_influx_config_dir }}"

HEALTH_URL = "{{ graphyard_echoport_backup_health_url }}"
HEALTH_EXPECTED_STATUS_RAW = "{{ graphyard_echoport_backup_health_expected_status }}"
HEALTH_RETRIES_RAW = "{{ graphyard_echoport_backup_health_retries }}"
HEALTH_DELAY_RAW = "{{ graphyard_echoport_backup_health_delay }}"
HEALTH_FORWARD_PROTO = "{{ graphyard_echoport_backup_health_forwarded_proto }}"

ENFORCE_HOST_MATCH_RAW = "{{ graphyard_echoport_backup_enforce_host_match }}"
CHECK_DISK_SPACE_RAW = "{{ graphyard_echoport_backup_check_disk_space }}"
DISK_SPACE_MULTIPLIER_RAW = "{{ graphyard_echoport_backup_disk_space_multiplier }}"
CREATE_SAFETY_SNAPSHOT_RAW = "{{ graphyard_echoport_backup_create_safety_snapshot }}"
ROLLBACK_ON_FAILURE_RAW = "{{ graphyard_echoport_backup_rollback_on_failure }}"
CLEANUP_SAFETY_SNAPSHOT_RAW = "{{ graphyard_echoport_backup_cleanup_safety_snapshot }}"
INCLUDE_INFLUX_CONFIG_RAW = "{{ graphyard_echoport_backup_include_influx_config }}"
RESTORE_FAILPOINT_DEFAULT_RAW = "{{ graphyard_echoport_backup_restore_failpoint | default('', true) }}"

ALLOWED_ROOTS_RAW = "{{ graphyard_echoport_backup_allowed_roots | join(',') }}"


def parse_bool(value: str, default: bool = False) -> bool:
    if value is None:
        return default
    normalized = str(value).strip().lower()
    if normalized in {"1", "true", "yes", "on"}:
        return True
    if normalized in {"0", "false", "no", "off"}:
        return False
    return default


def parse_int(value: str, default: int) -> int:
    try:
        return int(str(value).strip())
    except Exception:
        return default


def parse_float(value: str, default: float) -> float:
    try:
        return float(str(value).strip())
    except Exception:
        return default


HEALTH_EXPECTED_STATUS = parse_int(HEALTH_EXPECTED_STATUS_RAW, 200)
HEALTH_RETRIES = max(1, parse_int(HEALTH_RETRIES_RAW, 24))
HEALTH_DELAY = max(1, parse_int(HEALTH_DELAY_RAW, 5))
ENFORCE_HOST_MATCH = parse_bool(ENFORCE_HOST_MATCH_RAW, True)
CHECK_DISK_SPACE = parse_bool(CHECK_DISK_SPACE_RAW, True)
DISK_SPACE_MULTIPLIER = parse_float(DISK_SPACE_MULTIPLIER_RAW, 2.0)
CREATE_SAFETY_SNAPSHOT = parse_bool(CREATE_SAFETY_SNAPSHOT_RAW, True)
ROLLBACK_ON_FAILURE = parse_bool(ROLLBACK_ON_FAILURE_RAW, True)
CLEANUP_SAFETY_SNAPSHOT = parse_bool(CLEANUP_SAFETY_SNAPSHOT_RAW, True)
INCLUDE_INFLUX_CONFIG = parse_bool(INCLUDE_INFLUX_CONFIG_RAW, True)
ALLOWED_ROOTS = [item.strip() for item in ALLOWED_ROOTS_RAW.split(",") if item.strip()]
RESTORE_FAILPOINT_DEFAULT = str(RESTORE_FAILPOINT_DEFAULT_RAW or "").strip()


def read_config_file() -> Optional[Dict]:
    config_file = os.environ.get("DEPLOY_CONFIG_FILE")
    if "--config" in sys.argv:
        idx = sys.argv.index("--config")
        if idx + 1 < len(sys.argv):
            config_file = sys.argv[idx + 1]

    if not config_file or not Path(config_file).exists():
        return None

    try:
        with open(config_file, "r") as handle:
            return json.load(handle)
    except Exception as exc:
        print(f"Failed to read config file: {exc}", file=sys.stderr)
        return None


def _emit(obj: Dict[str, Any]) -> None:
    print(json.dumps(obj, ensure_ascii=False), flush=True)


def emit_step(name: str, state: str, message: str = "") -> None:
    payload = {"name": name, "state": state}
    if message:
        payload["message"] = message
    _emit(payload)


def emit_result(
    success: bool,
    bucket: str = "",
    key: str = "",
    size_bytes: int = 0,
    checksum_sha256: str = "",
    file_count: int = 0,
    error: str | None = None,
) -> None:
    result = {
        "success": success,
        "bucket": bucket,
        "key": key,
        "size_bytes": size_bytes,
        "checksum_sha256": checksum_sha256,
        "file_count": file_count,
    }
    if error:
        result["error"] = error
    emit_step("result", "success" if success else "failure", f"ECHOPORT_RESULT:{json.dumps(result)}")


def finish_stdout(status: str, message: str = "") -> None:
    payload = {"event": "finish", "status": status}
    if message:
        payload["message"] = message
    _emit(payload)


def safe_error(exc: Exception) -> str:
    if isinstance(exc, subprocess.CalledProcessError):
        stderr = (exc.stderr or "").strip()
        stdout = (exc.stdout or "").strip()
        if stderr:
            return stderr
        if stdout:
            return stdout
        return f"Command failed with exit code {exc.returncode}"
    return str(exc)


def run_cmd(args: list[str], check: bool = True) -> subprocess.CompletedProcess:
    result = subprocess.run(args, capture_output=True, text=True)
    if check and result.returncode != 0:
        raise subprocess.CalledProcessError(result.returncode, args, result.stdout, result.stderr)
    return result


def calculate_sha256(filepath: Path) -> str:
    sha256_hash = hashlib.sha256()
    with open(filepath, "rb") as handle:
        for chunk in iter(lambda: handle.read(8192), b""):
            sha256_hash.update(chunk)
    return sha256_hash.hexdigest()


def normalize_root(root: str) -> str:
    normalized = os.path.realpath(root)
    if not normalized.endswith(os.sep):
        normalized += os.sep
    return normalized


def path_in_allowed_roots(path: str) -> bool:
    if not path:
        return False
    resolved = os.path.realpath(path)
    for root in ALLOWED_ROOTS:
        normalized_root = normalize_root(root)
        if resolved.startswith(normalized_root) or resolved == normalized_root.rstrip(os.sep):
            return True
    return False


def validate_config_paths(mode: str) -> None:
    configured_paths = [
        SITE_ROOT,
        DJANGO_DIR,
        MANAGE_PY,
        ENV_FILE,
        DB_PATH,
        WEB_UNIT,
        AGENT_UNIT,
        INFLUX_DATA_DIR,
        INFLUX_CONFIG_DIR,
        TEMP_DIR,
    ]

    for cfg_path in configured_paths:
        if cfg_path and not path_in_allowed_roots(cfg_path):
            raise ValueError(f"Configured path outside allowed roots: {cfg_path}")

    required_files = [VENV_PYTHON, MANAGE_PY, ENV_FILE, WEB_UNIT, AGENT_UNIT]
    for required_file in required_files:
        if not Path(required_file).is_file():
            raise FileNotFoundError(f"Required file missing: {required_file}")

    required_dirs = [SITE_ROOT, DJANGO_DIR, INFLUX_DATA_DIR]
    if INCLUDE_INFLUX_CONFIG:
        required_dirs.append(INFLUX_CONFIG_DIR)

    for required_dir in required_dirs:
        if not Path(required_dir).is_dir():
            raise FileNotFoundError(f"Required directory missing: {required_dir}")

    if mode == "backup" and not Path(DB_PATH).is_file():
        raise FileNotFoundError(f"Graphyard SQLite database missing: {DB_PATH}")


def ensure_binaries() -> None:
    needed = [MC_PATH, "sqlite3", "rsync", "tar", "systemctl", "docker", "bash", "runuser"]
    for binary in needed:
        if binary.startswith("/"):
            if not Path(binary).exists():
                raise FileNotFoundError(f"Required binary not found: {binary}")
        else:
            result = run_cmd(["which", binary], check=False)
            if result.returncode != 0:
                raise FileNotFoundError(f"Required binary not found in PATH: {binary}")


def sqlite_backup(db_path: str, backup_path: Path) -> None:
    if not Path(db_path).is_file():
        raise FileNotFoundError(f"SQLite database missing: {db_path}")
    backup_path.parent.mkdir(parents=True, exist_ok=True)
    result = subprocess.run(
        ["sqlite3", db_path, f".backup '{backup_path}'"],
        capture_output=True,
        text=True,
        shell=False,
    )
    if result.returncode != 0:
        raise RuntimeError(f"sqlite3 backup failed: {(result.stderr or result.stdout).strip()}")
    sqlite_integrity_check(str(backup_path))


def sqlite_integrity_check(db_path: str) -> None:
    result = run_cmd(["sqlite3", db_path, "PRAGMA integrity_check;"], check=False)
    if result.returncode != 0:
        raise RuntimeError((result.stderr or result.stdout or "").strip() or "SQLite integrity check failed")
    if "ok" not in result.stdout.lower():
        raise RuntimeError(f"SQLite integrity check failed for {db_path}: {result.stdout.strip()}")


def remove_sqlite_wal_shm(db_path: str) -> None:
    for suffix in ("-wal", "-shm"):
        candidate = Path(f"{db_path}{suffix}")
        if candidate.exists():
            candidate.unlink()


def rsync_dir(src_dir: Path, dst_dir: Path, delete: bool = True) -> None:
    if not src_dir.exists() or not src_dir.is_dir():
        return
    dst_dir.mkdir(parents=True, exist_ok=True)
    args = ["rsync", "-a"]
    if delete:
        args.append("--delete")
    args.extend([f"{src_dir}/", f"{dst_dir}/"])
    run_cmd(args)


def copy_file_optional(src: Path, dst: Path) -> bool:
    if not src.exists() or not src.is_file():
        return False
    dst.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(src, dst)
    return True


def set_mode(path: Path, mode: str) -> None:
    if path.exists():
        run_cmd(["chmod", mode, str(path)])


def set_owner(path: Path, owner: str, recursive: bool = False) -> None:
    if not owner or not path.exists():
        return
    args = ["chown"]
    if recursive:
        args.append("-R")
    args.extend([owner, str(path)])
    run_cmd(args)


def service_is_active(service_name: str) -> bool:
    result = run_cmd(["systemctl", "is-active", service_name], check=False)
    return result.stdout.strip() == "active"


def stop_service(service_name: str) -> None:
    run_cmd(["systemctl", "stop", service_name])


def start_service(service_name: str) -> None:
    run_cmd(["systemctl", "start", service_name])


def wait_service_active(service_name: str, timeout_seconds: int = 120) -> None:
    deadline = time.time() + timeout_seconds
    while time.time() < deadline:
        if service_is_active(service_name):
            return
        time.sleep(2)
    raise RuntimeError(f"Service did not become active in {timeout_seconds}s: {service_name}")


def assert_influx_container_running() -> None:
    result = run_cmd(
        ["docker", "inspect", "-f", "{% raw %}{{.State.Running}}{% endraw %}", INFLUX_CONTAINER],
        check=False,
    )
    if result.returncode != 0 or result.stdout.strip() != "true":
        raise RuntimeError(f"Influx container is not running: {INFLUX_CONTAINER}")


def run_influx_cli(cli_args: list[str], check: bool = True) -> subprocess.CompletedProcess:
    assert_influx_container_running()
    command = " ".join(["influx", *[shlex.quote(arg) for arg in cli_args]])
    result = subprocess.run(
        ["docker", "exec", INFLUX_CONTAINER, "sh", "-lc", command],
        capture_output=True,
        text=True,
    )
    if check and result.returncode != 0:
        raise subprocess.CalledProcessError(
            result.returncode,
            ["docker", "exec", INFLUX_CONTAINER, "sh", "-lc", command],
            result.stdout,
            result.stderr,
        )
    return result


def run_influx_backup(out_dir: Path, label: str) -> None:
    out_dir.mkdir(parents=True, exist_ok=True)
    container_tmp = f"/tmp/graphyard-influx-{label}-{int(time.time())}"
    try:
        run_influx_cli(["backup", container_tmp])
        run_cmd(["docker", "cp", f"{INFLUX_CONTAINER}:{container_tmp}/.", str(out_dir)])
        if not any(out_dir.rglob("*")):
            raise RuntimeError("Influx backup directory is empty")
    finally:
        run_cmd(["docker", "exec", INFLUX_CONTAINER, "sh", "-lc", f"rm -rf {shlex.quote(container_tmp)}"], check=False)


def run_influx_restore(backup_dir: Path, label: str) -> None:
    if not backup_dir.exists() or not backup_dir.is_dir():
        raise FileNotFoundError(f"Influx backup directory missing: {backup_dir}")
    container_tmp = f"/tmp/graphyard-influx-restore-{label}-{int(time.time())}"
    try:
        run_cmd(["docker", "exec", INFLUX_CONTAINER, "sh", "-lc", f"rm -rf {shlex.quote(container_tmp)} && mkdir -p {shlex.quote(container_tmp)}"])
        run_cmd(["docker", "cp", f"{backup_dir}/.", f"{INFLUX_CONTAINER}:{container_tmp}"])
        run_influx_cli(["restore", "--full", container_tmp])
    finally:
        run_cmd(["docker", "exec", INFLUX_CONTAINER, "sh", "-lc", f"rm -rf {shlex.quote(container_tmp)}"], check=False)


def get_tree_size(path: Path) -> int:
    if not path.exists():
        return 0
    if path.is_file():
        return path.stat().st_size

    total = 0
    for entry in path.rglob("*"):
        try:
            if entry.is_file():
                total += entry.stat().st_size
        except Exception:
            continue
    return total


def get_free_bytes_for_path(path: Path) -> int:
    candidate = path
    while not candidate.exists() and candidate != candidate.parent:
        candidate = candidate.parent
    stat = os.statvfs(candidate)
    return stat.f_bavail * stat.f_frsize


def disk_space_precheck(tarball_path: Path) -> None:
    if not CHECK_DISK_SPACE:
        return

    with tarfile.open(tarball_path, "r:gz") as tar:
        extracted_payload_size = sum(member.size for member in tar.getmembers())

    safety_snapshot_estimate = (
        get_tree_size(Path(DB_PATH))
        + get_tree_size(Path(INFLUX_DATA_DIR))
        + (get_tree_size(Path(INFLUX_CONFIG_DIR)) if INCLUDE_INFLUX_CONFIG else 0)
        + get_tree_size(Path(ENV_FILE))
        + get_tree_size(Path(WEB_UNIT))
        + get_tree_size(Path(AGENT_UNIT))
    )

    required_bytes = int(math.ceil(extracted_payload_size * DISK_SPACE_MULTIPLIER) + safety_snapshot_estimate)
    free_bytes = min(
        get_free_bytes_for_path(Path(TEMP_DIR)),
        get_free_bytes_for_path(Path(DB_PATH).parent),
        get_free_bytes_for_path(Path(INFLUX_DATA_DIR)),
    )
    if free_bytes < required_bytes:
        raise RuntimeError(
            f"Insufficient disk space for restore. required={required_bytes} free={free_bytes} "
            f"(payload={extracted_payload_size}, safety_snapshot={safety_snapshot_estimate}, "
            f"multiplier={DISK_SPACE_MULTIPLIER})"
        )


def _is_safe_tar_member(member: tarfile.TarInfo, extract_dir: Path) -> tuple[bool, str]:
    if member.isdev() or member.ischr() or member.isblk():
        return False, f"Tarball contains device node: {member.name}"
    if member.isfifo():
        return False, f"Tarball contains FIFO: {member.name}"
    if member.name.startswith("/"):
        return False, f"Tarball contains absolute path: {member.name}"
    if ".." in member.name:
        return False, f"Tarball contains path traversal: {member.name}"

    target_path = (extract_dir / member.name).resolve()
    try:
        target_path.relative_to(extract_dir.resolve())
    except ValueError:
        return False, f"Tarball member escapes extraction root: {member.name}"

    if member.issym():
        link_target = Path(member.linkname)
        if link_target.is_absolute():
            return False, f"Tarball symlink with absolute target: {member.name} -> {member.linkname}"
        link_resolved = (target_path.parent / link_target).resolve()
        try:
            link_resolved.relative_to(extract_dir.resolve())
        except ValueError:
            return False, f"Tarball symlink escapes extraction root: {member.name} -> {member.linkname}"

    if member.islnk():
        link_target = (extract_dir / member.linkname).resolve()
        try:
            link_target.relative_to(extract_dir.resolve())
        except ValueError:
            return False, f"Tarball hardlink escapes extraction root: {member.name} -> {member.linkname}"

    return True, ""


def safe_extract_tarball(tarball_path: Path, extract_dir: Path) -> None:
    with tarfile.open(tarball_path, "r:gz") as tar:
        safe_members = []
        for member in tar.getmembers():
            is_safe, error = _is_safe_tar_member(member, extract_dir)
            if not is_safe:
                raise ValueError(error)
            safe_members.append(member)
        tar.extractall(extract_dir, members=safe_members)


def make_checksum_manifest(root_dir: Path, manifest_path: Path) -> None:
    entries: list[Path] = []
    for path in root_dir.rglob("*"):
        if not path.is_file():
            continue
        if path.resolve() == manifest_path.resolve():
            continue
        entries.append(path)

    entries.sort(key=lambda p: p.relative_to(root_dir).as_posix())
    lines: list[str] = []
    for item in entries:
        rel = item.relative_to(root_dir).as_posix()
        lines.append(f"{calculate_sha256(item)}  ./{rel}")

    manifest_path.write_text("\n".join(lines) + ("\n" if lines else ""))


def verify_checksum_manifest(root_dir: Path, manifest_path: Path) -> None:
    if not manifest_path.exists():
        raise FileNotFoundError("manifest.sha256 missing from backup archive")

    lines = [line.strip() for line in manifest_path.read_text().splitlines() if line.strip()]
    for line in lines:
        parts = line.split("  ", 1)
        if len(parts) != 2:
            raise ValueError(f"Invalid checksum manifest line: {line}")
        expected, rel_path = parts
        clean_rel = rel_path[2:] if rel_path.startswith("./") else rel_path
        target = root_dir / clean_rel
        if not target.exists() or not target.is_file():
            raise FileNotFoundError(f"Checksum target missing: {clean_rel}")
        actual = calculate_sha256(target)
        if actual != expected:
            raise ValueError(f"Checksum mismatch for {clean_rel}: expected {expected}, got {actual}")


def create_tarball(source_dir: Path, tarball_path: Path) -> None:
    with tarfile.open(tarball_path, "w:gz") as tar:
        for item in sorted(source_dir.iterdir(), key=lambda p: p.name):
            tar.add(item, arcname=item.name)


def upload_to_minio(tarball_path: Path, bucket: str, key: str) -> None:
    run_cmd([MC_PATH, "cp", str(tarball_path), f"{MINIO_ALIAS}/{bucket}/{key}"])


def download_from_minio(bucket: str, key: str, dest_path: Path) -> None:
    run_cmd([MC_PATH, "cp", f"{MINIO_ALIAS}/{bucket}/{key}", str(dest_path)])
    if not dest_path.exists():
        raise RuntimeError(f"Download failed, file missing at {dest_path}")


def run_graphyard_manage(command_args: list[str]) -> None:
    quoted_parts = [
        f"cd {shlex.quote(DJANGO_DIR)}",
        "set -a",
        f". {shlex.quote(ENV_FILE)}",
        "set +a",
        " ".join([shlex.quote(VENV_PYTHON), shlex.quote(MANAGE_PY), *[shlex.quote(arg) for arg in command_args]]),
    ]
    shell_cmd = " && ".join(quoted_parts)
    run_cmd(["runuser", "-u", GRAPHYARD_USER, "--", "bash", "-lc", shell_cmd])


def verify_health_payload(payload: Dict[str, Any]) -> None:
    if payload.get("status") != "ok":
        raise RuntimeError(f"Unexpected Graphyard health status: {payload.get('status')}")

    components = payload.get("components", {})
    if components.get("database", {}).get("status") != "ok":
        raise RuntimeError(f"Graphyard database health not ok: {components.get('database')}")
    if components.get("influxdb", {}).get("status") != "ok":
        raise RuntimeError(f"Graphyard InfluxDB health not ok: {components.get('influxdb')}")

    pipelines = components.get("pipelines", {})
    collectors_status = pipelines.get("metric_collectors", {}).get("status")
    evaluator_status = pipelines.get("condition_evaluator", {}).get("status")
    if collectors_status and collectors_status != "ok":
        raise RuntimeError(f"Graphyard metric collectors health not ok: {collectors_status}")
    if evaluator_status and evaluator_status != "ok":
        raise RuntimeError(f"Graphyard condition evaluator health not ok: {evaluator_status}")


def run_health_check() -> None:
    headers: dict[str, str] = {}
    if HEALTH_FORWARD_PROTO:
        headers["X-Forwarded-Proto"] = HEALTH_FORWARD_PROTO

    last_error = ""
    for attempt in range(1, HEALTH_RETRIES + 1):
        try:
            request = Request(HEALTH_URL, method="GET", headers=headers)
            with urlopen(request, timeout=10) as response:
                if response.status != HEALTH_EXPECTED_STATUS:
                    raise RuntimeError(
                        f"Unexpected HTTP status {response.status} for {HEALTH_URL}, "
                        f"expected {HEALTH_EXPECTED_STATUS}"
                    )
                payload = json.loads(response.read().decode("utf-8"))
                verify_health_payload(payload)
                return
        except URLError as exc:
            last_error = str(exc)
        except Exception as exc:  # noqa: BLE001
            last_error = str(exc)

        if attempt < HEALTH_RETRIES:
            time.sleep(HEALTH_DELAY)

    raise RuntimeError(
        f"Health check failed after {HEALTH_RETRIES} attempts: {last_error or HEALTH_URL}"
    )


def validate_archive(extract_dir: Path) -> dict[str, Any]:
    manifest_path = extract_dir / "manifest.json"
    if not manifest_path.exists():
        raise FileNotFoundError("manifest.json missing from backup archive")

    manifest = json.loads(manifest_path.read_text())
    if manifest.get("schema_version") != 1:
        raise ValueError(f"Unsupported manifest schema_version: {manifest.get('schema_version')}")
    if manifest.get("target") != "graphyard":
        raise ValueError(f"Unexpected target in manifest: {manifest.get('target')}")
    if ENFORCE_HOST_MATCH and manifest.get("host") not in {"", os.uname().nodename}:
        raise ValueError(
            f"Refusing cross-host restore: manifest host={manifest.get('host')} current={os.uname().nodename}"
        )
    if manifest.get("coverage", {}).get("grafana_state_included"):
        raise ValueError("Unexpected Grafana state in archive; Graphyard contract excludes Grafana DB")

    required_paths = [
        extract_dir / "sqlite" / "db.sqlite3",
        extract_dir / "influx-backup",
        extract_dir / "config" / "graphyard.env",
        extract_dir / "systemd" / "graphyard-web.service",
        extract_dir / "systemd" / "graphyard-agent.service",
    ]
    for required in required_paths:
        if not required.exists():
            raise FileNotFoundError(f"Required restore payload missing: {required.relative_to(extract_dir)}")

    if INCLUDE_INFLUX_CONFIG and not (extract_dir / "config" / "influxdb2-config").exists():
        raise FileNotFoundError("Influx config payload missing from archive")

    return manifest


def create_safety_snapshot(snapshot_dir: Path) -> None:
    snapshot_dir.mkdir(parents=True, exist_ok=True)
    sqlite_dir = snapshot_dir / "sqlite"
    influx_dir = snapshot_dir / "influx-backup"
    config_dir = snapshot_dir / "config"
    systemd_dir = snapshot_dir / "systemd"

    sqlite_dir.mkdir(parents=True, exist_ok=True)
    config_dir.mkdir(parents=True, exist_ok=True)
    systemd_dir.mkdir(parents=True, exist_ok=True)

    sqlite_backup(DB_PATH, sqlite_dir / "db.sqlite3")
    run_influx_backup(influx_dir, "safety")

    copy_file_optional(Path(ENV_FILE), config_dir / "graphyard.env")
    if INCLUDE_INFLUX_CONFIG:
        rsync_dir(Path(INFLUX_CONFIG_DIR), config_dir / "influxdb2-config", delete=True)

    copy_file_optional(Path(WEB_UNIT), systemd_dir / "graphyard-web.service")
    copy_file_optional(Path(AGENT_UNIT), systemd_dir / "graphyard-agent.service")


def restore_config_from_stage(stage_dir: Path) -> None:
    env_src = stage_dir / "config" / "graphyard.env"
    if env_src.exists():
        Path(ENV_FILE).parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(env_src, ENV_FILE)
        set_owner(Path(ENV_FILE), f"root:{GRAPHYARD_USER}")
        set_mode(Path(ENV_FILE), "0640")

    if INCLUDE_INFLUX_CONFIG:
        influx_cfg_src = stage_dir / "config" / "influxdb2-config"
        if influx_cfg_src.exists():
            rsync_dir(influx_cfg_src, Path(INFLUX_CONFIG_DIR), delete=True)

    web_src = stage_dir / "systemd" / "graphyard-web.service"
    if web_src.exists():
        Path(WEB_UNIT).parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(web_src, WEB_UNIT)
        set_mode(Path(WEB_UNIT), "0644")

    agent_src = stage_dir / "systemd" / "graphyard-agent.service"
    if agent_src.exists():
        Path(AGENT_UNIT).parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(agent_src, AGENT_UNIT)
        set_mode(Path(AGENT_UNIT), "0644")

    run_cmd(["systemctl", "daemon-reload"])


def restore_sqlite_from_stage(stage_dir: Path) -> None:
    db_src = stage_dir / "sqlite" / "db.sqlite3"
    if not db_src.exists():
        raise FileNotFoundError("SQLite backup missing from restore payload")

    Path(DB_PATH).parent.mkdir(parents=True, exist_ok=True)
    remove_sqlite_wal_shm(DB_PATH)
    shutil.copy2(db_src, DB_PATH)
    remove_sqlite_wal_shm(DB_PATH)
    set_owner(Path(DB_PATH), f"{GRAPHYARD_USER}:{GRAPHYARD_USER}")
    set_mode(Path(DB_PATH), "0640")
    sqlite_integrity_check(DB_PATH)


def stop_graphyard_services() -> None:
    if service_is_active(AGENT_SERVICE):
        stop_service(AGENT_SERVICE)
    if service_is_active(WEB_SERVICE):
        stop_service(WEB_SERVICE)


def start_graphyard_web() -> None:
    start_service(WEB_SERVICE)
    wait_service_active(WEB_SERVICE)


def validate_graphyard_agent_once() -> None:
    run_graphyard_manage(["start_agent", "--run-once"])


def start_graphyard_agent() -> None:
    start_service(AGENT_SERVICE)
    wait_service_active(AGENT_SERVICE)


def best_effort_start_services() -> list[str]:
    errors: list[str] = []
    for service_name in (WEB_SERVICE, AGENT_SERVICE):
        try:
            if not service_is_active(service_name):
                start_service(service_name)
                wait_service_active(service_name)
        except Exception as exc:  # noqa: BLE001
            errors.append(f"{service_name}: {exc}")
    return errors


def maybe_trigger_restore_failpoint(failpoint: str, expected: str) -> None:
    if failpoint == expected:
        raise RuntimeError(f"Injected restore failure at failpoint: {expected}")


def restore_stage(stage_dir: Path, label: str) -> None:
    run_influx_restore(stage_dir / "influx-backup", label)
    restore_sqlite_from_stage(stage_dir)
    restore_config_from_stage(stage_dir)


def rollback_from_snapshot(snapshot_dir: Path) -> None:
    stop_graphyard_services()
    restore_stage(snapshot_dir, "rollback")
    start_graphyard_web()
    validate_graphyard_agent_once()
    start_graphyard_agent()
    run_health_check()


def backup_flow(cenv: Dict[str, str]) -> int:
    target_name = cenv.get("ECHOPORT_TARGET", "graphyard")
    run_id = cenv.get("ECHOPORT_RUN_ID", "0")
    timestamp = cenv.get("ECHOPORT_TIMESTAMP") or datetime.now(timezone.utc).strftime("%Y-%m-%dT%H-%M-%S")
    key_prefix = cenv.get("ECHOPORT_KEY_PREFIX") or f"{target_name}/{timestamp}"
    bucket = cenv.get("ECHOPORT_BUCKET", DEFAULT_BUCKET)

    work_dir = Path(
        tempfile.mkdtemp(prefix="graphyard-backup-", dir=TEMP_DIR if Path(TEMP_DIR).exists() else None)
    )
    payload = work_dir / "payload"
    payload.mkdir(parents=True, exist_ok=True)

    try:
        emit_step("init", "running", "Validating Graphyard backup configuration")
        validate_config_paths("backup")
        ensure_binaries()
        assert_influx_container_running()
        emit_step("init", "success", f"Configuration loaded for {target_name} run {run_id}")

        emit_step("backup_sqlite", "running", "Creating SQLite backup")
        sqlite_backup(DB_PATH, payload / "sqlite" / "db.sqlite3")
        emit_step("backup_sqlite", "success", "SQLite backup created")

        emit_step("backup_influx", "running", "Creating native InfluxDB backup")
        run_influx_backup(payload / "influx-backup", "backup")
        emit_step("backup_influx", "success", "InfluxDB backup created")

        emit_step("copy_config", "running", "Copying Graphyard env and systemd payload")
        copy_file_optional(Path(ENV_FILE), payload / "config" / "graphyard.env")
        if INCLUDE_INFLUX_CONFIG:
            rsync_dir(Path(INFLUX_CONFIG_DIR), payload / "config" / "influxdb2-config", delete=True)
        copy_file_optional(Path(WEB_UNIT), payload / "systemd" / "graphyard-web.service")
        copy_file_optional(Path(AGENT_UNIT), payload / "systemd" / "graphyard-agent.service")
        emit_step("copy_config", "success", "Config and systemd payload copied")

        manifest = {
            "schema_version": 1,
            "target": target_name,
            "run_id": run_id,
            "generated_at": datetime.now(timezone.utc).isoformat(),
            "host": os.uname().nodename,
            "paths": {
                "db_path": DB_PATH,
                "env_file": ENV_FILE,
                "web_unit": WEB_UNIT,
                "agent_unit": AGENT_UNIT,
                "influx_container": INFLUX_CONTAINER,
                "influx_data_dir": INFLUX_DATA_DIR,
                "influx_config_dir": INFLUX_CONFIG_DIR if INCLUDE_INFLUX_CONFIG else "",
            },
            "services": {
                "web": WEB_SERVICE,
                "agent": AGENT_SERVICE,
            },
            "restore_contract": {
                "order": [
                    "restore_influx",
                    "restore_sqlite",
                    "restore_config",
                    "start_web",
                    "validate_agent",
                    "start_agent",
                    "health_check",
                ],
                "create_safety_snapshot": CREATE_SAFETY_SNAPSHOT,
                "rollback_on_failure": ROLLBACK_ON_FAILURE,
                "enforce_host_match": ENFORCE_HOST_MATCH,
            },
            "coverage": {
                "sqlite_included": True,
                "influx_native_backup_included": True,
                "influx_config_included": INCLUDE_INFLUX_CONFIG,
                "grafana_state_included": False,
                "grafana_exclusion_reason": (
                    "Grafana dashboards and datasource/admin bootstrap are managed declaratively "
                    "outside the Graphyard backup artifact."
                ),
            },
        }
        (payload / "manifest.json").write_text(json.dumps(manifest, indent=2))
        make_checksum_manifest(payload, payload / "manifest.sha256")

        emit_step("upload", "running", "Creating archive and uploading to MinIO")
        tarball_path = work_dir / f"{timestamp}.tar.gz"
        create_tarball(payload, tarball_path)
        checksum = calculate_sha256(tarball_path)
        storage_key = f"{key_prefix}.tar.gz"
        upload_to_minio(tarball_path, bucket, storage_key)
        emit_step("upload", "success", f"Uploaded {storage_key}")

        emit_step("verify", "running", "Verifying uploaded object in MinIO")
        run_cmd([MC_PATH, "stat", f"{MINIO_ALIAS}/{bucket}/{storage_key}"])
        emit_step("verify", "success", "MinIO object verified")

        file_count = sum(1 for path in payload.rglob("*") if path.is_file())
        emit_result(
            success=True,
            bucket=bucket,
            key=storage_key,
            size_bytes=tarball_path.stat().st_size,
            checksum_sha256=checksum,
            file_count=file_count,
        )
        finish_stdout("success", f"Backup completed: {storage_key}")
        return 0
    except Exception as exc:  # noqa: BLE001
        message = safe_error(exc)
        emit_step("error", "failure", message)
        emit_result(success=False, error=message)
        finish_stdout("failure", f"Backup failed: {message}")
        return 1
    finally:
        shutil.rmtree(work_dir, ignore_errors=True)


def restore_flow(cenv: Dict[str, str]) -> int:
    target_name = cenv.get("ECHOPORT_TARGET", "graphyard")
    restore_id = cenv.get("ECHOPORT_RESTORE_ID", "0")
    bucket = cenv.get("ECHOPORT_BUCKET", DEFAULT_BUCKET)
    storage_key = cenv.get("ECHOPORT_KEY", "")
    expected_checksum = cenv.get("ECHOPORT_CHECKSUM", "")
    restore_failpoint = str(
        cenv.get("GRAPHYARD_RESTORE_FAILPOINT", RESTORE_FAILPOINT_DEFAULT)
    ).strip()

    if not storage_key:
        error = "ECHOPORT_KEY missing for restore"
        emit_step("init", "failure", error)
        emit_result(success=False, error=error)
        finish_stdout("failure", error)
        return 1
    if not expected_checksum:
        error = "ECHOPORT_CHECKSUM missing for restore"
        emit_step("init", "failure", error)
        emit_result(success=False, error=error)
        finish_stdout("failure", error)
        return 1

    work_dir = Path(
        tempfile.mkdtemp(prefix="graphyard-restore-", dir=TEMP_DIR if Path(TEMP_DIR).exists() else None)
    )
    tarball_path = work_dir / "backup.tar.gz"
    extract_dir = work_dir / "extract"
    extract_dir.mkdir(parents=True, exist_ok=True)
    safety_snapshot_dir = work_dir / "safety"

    services_stopped = False
    destructive_started = False
    rollback_executed = False

    try:
        emit_step("init", "running", "Validating Graphyard restore configuration")
        validate_config_paths("restore")
        ensure_binaries()
        assert_influx_container_running()
        emit_step("init", "success", f"Configuration loaded for {target_name} restore {restore_id}")

        emit_step("download", "running", "Downloading archive from MinIO")
        download_from_minio(bucket, storage_key, tarball_path)
        emit_step("download", "success", f"Downloaded {storage_key}")

        emit_step("verify_checksum", "running", "Verifying archive checksum")
        actual_checksum = calculate_sha256(tarball_path)
        if actual_checksum != expected_checksum:
            raise RuntimeError(f"Checksum mismatch: expected {expected_checksum}, got {actual_checksum}")
        emit_step("verify_checksum", "success", "Archive checksum verified")

        emit_step("extract", "running", "Extracting archive")
        safe_extract_tarball(tarball_path, extract_dir)
        verify_checksum_manifest(extract_dir, extract_dir / "manifest.sha256")
        emit_step("extract", "success", "Archive extracted and validated")

        emit_step("validate", "running", "Validating restore manifest")
        validate_archive(extract_dir)
        emit_step("validate", "success", "Restore manifest validated")

        emit_step("precheck", "running", "Checking disk space for restore")
        disk_space_precheck(tarball_path)
        emit_step("precheck", "success", "Disk space precheck passed")

        emit_step("safety_snapshot", "running", "Creating pre-restore safety snapshot")
        if CREATE_SAFETY_SNAPSHOT:
            create_safety_snapshot(safety_snapshot_dir)
            emit_step("safety_snapshot", "success", "Safety snapshot created")
        else:
            emit_step("safety_snapshot", "success", "Safety snapshot skipped")

        emit_step("stop_services", "running", "Stopping Graphyard services")
        stop_graphyard_services()
        services_stopped = True
        emit_step("stop_services", "success", "Graphyard services stopped")

        destructive_started = True

        emit_step("restore_influx", "running", "Restoring InfluxDB from native backup")
        run_influx_restore(extract_dir / "influx-backup", "restore")
        emit_step("restore_influx", "success", "InfluxDB restore completed")
        maybe_trigger_restore_failpoint(restore_failpoint, "after_restore_influx")

        emit_step("restore_sqlite", "running", "Restoring Graphyard SQLite database")
        restore_sqlite_from_stage(extract_dir)
        emit_step("restore_sqlite", "success", "SQLite restore completed")
        maybe_trigger_restore_failpoint(restore_failpoint, "after_restore_sqlite")

        emit_step("restore_config", "running", "Restoring Graphyard env and systemd files")
        restore_config_from_stage(extract_dir)
        emit_step("restore_config", "success", "Graphyard env and systemd files restored")
        maybe_trigger_restore_failpoint(restore_failpoint, "after_restore_config")

        emit_step("start_web", "running", f"Starting {WEB_SERVICE}")
        start_graphyard_web()
        emit_step("start_web", "success", f"{WEB_SERVICE} is active")

        emit_step("validate_agent", "running", "Running Graphyard one-shot validation pass")
        validate_graphyard_agent_once()
        emit_step("validate_agent", "success", "Graphyard one-shot validation completed")

        emit_step("start_agent", "running", f"Starting {AGENT_SERVICE}")
        start_graphyard_agent()
        emit_step("start_agent", "success", f"{AGENT_SERVICE} is active")

        maybe_trigger_restore_failpoint(restore_failpoint, "before_health_check")
        emit_step("health_check", "running", "Checking Graphyard health endpoint")
        run_health_check()
        emit_step("health_check", "success", "Graphyard health check passed")

        emit_step("rollback", "success", "Rollback not required")

        emit_step("cleanup", "running", "Cleaning temporary restore state")
        if CLEANUP_SAFETY_SNAPSHOT and safety_snapshot_dir.exists():
            shutil.rmtree(safety_snapshot_dir, ignore_errors=True)
        emit_step("cleanup", "success", "Cleanup complete")

        file_count = sum(1 for path in extract_dir.rglob("*") if path.is_file())
        emit_result(
            success=True,
            bucket=bucket,
            key=storage_key,
            size_bytes=tarball_path.stat().st_size,
            checksum_sha256=actual_checksum,
            file_count=file_count,
        )
        finish_stdout("success", "Restore completed")
        return 0
    except Exception as exc:  # noqa: BLE001
        message = safe_error(exc)
        rollback_error = ""
        if destructive_started and safety_snapshot_dir.exists() and ROLLBACK_ON_FAILURE:
            emit_step("rollback", "running", "Restore failed; attempting rollback from safety snapshot")
            try:
                rollback_from_snapshot(safety_snapshot_dir)
                rollback_executed = True
                emit_step("rollback", "success", "Rollback completed")
            except Exception as rollback_exc:  # noqa: BLE001
                rollback_error = safe_error(rollback_exc)
                emit_step("rollback", "failure", rollback_error)
        elif services_stopped:
            restart_errors = best_effort_start_services()
            if restart_errors:
                rollback_error = "; ".join(restart_errors)

        if rollback_executed:
            message = f"{message} (rollback executed)"
        elif rollback_error:
            message = f"{message} (rollback failed: {rollback_error})"

        emit_step("error", "failure", message)
        emit_result(success=False, error=message)
        finish_stdout("failure", f"Restore failed: {message}")
        return 1
    finally:
        shutil.rmtree(work_dir, ignore_errors=True)


def build_context(config: Dict[str, Any]) -> Dict[str, str]:
    context = config.get("context", {}) if isinstance(config, dict) else {}
    env_context = context.get("env", {}) if isinstance(context, dict) else {}
    if not isinstance(env_context, dict):
        env_context = {}
    if not env_context and isinstance(context, dict):
        env_context = context

    def get_ctx(key: str, default: str = "") -> str:
        if key in env_context:
            value = env_context[key]
        else:
            value = os.environ.get(key, default)
        return "" if value is None else str(value)

    action = get_ctx("ECHOPORT_ACTION", "backup").strip().lower()
    context = {
        "ECHOPORT_ACTION": action,
        "ECHOPORT_TARGET": get_ctx("ECHOPORT_TARGET", "graphyard"),
        "ECHOPORT_RUN_ID": get_ctx("ECHOPORT_RUN_ID", "0"),
        "ECHOPORT_RESTORE_ID": get_ctx("ECHOPORT_RESTORE_ID", "0"),
        "ECHOPORT_TIMESTAMP": get_ctx("ECHOPORT_TIMESTAMP", ""),
        "ECHOPORT_BUCKET": get_ctx("ECHOPORT_BUCKET", DEFAULT_BUCKET),
        "ECHOPORT_KEY_PREFIX": get_ctx("ECHOPORT_KEY_PREFIX", ""),
        "ECHOPORT_KEY": get_ctx("ECHOPORT_KEY", ""),
        "ECHOPORT_CHECKSUM": get_ctx("ECHOPORT_CHECKSUM", ""),
    }
    if action not in {"backup", "restore"}:
        raise ValueError(f"Unsupported ECHOPORT_ACTION: {action}")
    return context


def main() -> int:
    config = read_config_file() or {}

    if os.geteuid() != 0:
        script_path = os.path.abspath(sys.argv[0])
        result = subprocess.run(
            ["sudo", "-n", script_path, *sys.argv[1:]],
            stdout=sys.stdout,
            stderr=sys.stderr,
        )
        return result.returncode

    try:
        Path(TEMP_DIR).mkdir(parents=True, exist_ok=True)
        cenv = build_context(config)
        if cenv["ECHOPORT_ACTION"] == "backup":
            return backup_flow(cenv)
        return restore_flow(cenv)
    except Exception as exc:  # noqa: BLE001
        message = safe_error(exc)
        emit_step("error", "failure", message)
        emit_result(success=False, error=message)
        finish_stdout("failure", message)
        return 1


if __name__ == "__main__":
    sys.exit(main())
