#!/usr/bin/env python3
"""
UniFi backup/restore runner for Echoport.

Service-owned same-host script:
- Backup: MongoDB dump (while service runs), stop service, copy data/config/system,
  archive upload to MinIO.
- Restore: download + checksum verify, stop service, MongoDB restore + file restore,
  service restart and health checks.
"""

import hashlib
import json
import os
import shutil
import ssl
import subprocess
import sys
import tarfile
import tempfile
import time
from datetime import datetime, timezone
from pathlib import Path
from typing import Dict, Optional
from urllib.error import URLError
from urllib.request import Request, urlopen

os.environ["PYTHONUNBUFFERED"] = "1"

# Shared configuration
MC_PATH = "{{ echoport_backup_mc_install_path }}"
MINIO_ALIAS = "{{ echoport_backup_minio_alias }}"
DEFAULT_BUCKET = "{{ echoport_backup_default_bucket }}"
TEMP_DIR = "{{ echoport_backup_temp_dir }}"

# UniFi-specific configuration
SERVICE_NAME = "{{ unifi_echoport_backup_service_name }}"
DATA_DIR = "{{ unifi_echoport_backup_data_dir }}"
DB_DIR = "{{ unifi_echoport_backup_db_dir }}"
SYSTEM_PROPERTIES = "{{ unifi_echoport_backup_system_properties }}"
KEYSTORE_PATH = "{{ unifi_echoport_backup_keystore_path }}"
ENV_FILE = "{{ unifi_echoport_backup_env_file }}"
SYSTEMD_UNIT = "{{ unifi_echoport_backup_systemd_unit }}"
TRAEFIK_CONFIG = "{{ unifi_echoport_backup_traefik_config }}"
MONGO_CREDENTIALS_FILE = "{{ unifi_echoport_backup_credentials_file }}"

UNIFI_OWNER = "{{ unifi_echoport_backup_owner }}"
UNIFI_GROUP = "{{ unifi_echoport_backup_group }}"
HEALTH_URL = "{{ unifi_echoport_backup_health_url }}"
HEALTH_RETRIES_RAW = "{{ unifi_echoport_backup_health_retries }}"
HEALTH_DELAY_RAW = "{{ unifi_echoport_backup_health_delay }}"
START_TIMEOUT_RAW = "{{ unifi_echoport_backup_start_timeout }}"

ALLOWED_ROOTS_RAW = "{{ unifi_echoport_backup_allowed_roots | join(',') }}"


def parse_int(value: str, default: int) -> int:
    try:
        return int(str(value).strip())
    except Exception:
        return default


HEALTH_RETRIES = max(1, parse_int(HEALTH_RETRIES_RAW, 12))
HEALTH_DELAY = max(1, parse_int(HEALTH_DELAY_RAW, 5))
START_TIMEOUT = max(30, parse_int(START_TIMEOUT_RAW, 180))
ALLOWED_ROOTS = [item.strip() for item in ALLOWED_ROOTS_RAW.split(",") if item.strip()]


def read_config_file() -> Optional[Dict]:
    config_file = os.environ.get("DEPLOY_CONFIG_FILE")
    if "--config" in sys.argv:
        idx = sys.argv.index("--config")
        if idx + 1 < len(sys.argv):
            config_file = sys.argv[idx + 1]

    if not config_file or not Path(config_file).exists():
        return None

    try:
        with open(config_file, "r") as handle:
            return json.load(handle)
    except Exception:
        return None


def _emit(obj: Dict) -> None:
    print(json.dumps(obj, ensure_ascii=False), flush=True)


def emit_step(name: str, state: str, message: str = "") -> None:
    payload = {"name": name, "state": state}
    if message:
        payload["message"] = message
    _emit(payload)


def emit_result(
    success: bool,
    bucket: str = "",
    key: str = "",
    size_bytes: int = 0,
    checksum_sha256: str = "",
    file_count: int = 0,
    error: str | None = None,
) -> None:
    result = {
        "success": success,
        "bucket": bucket,
        "key": key,
        "size_bytes": size_bytes,
        "checksum_sha256": checksum_sha256,
        "file_count": file_count,
    }
    if error:
        result["error"] = error
    emit_step("result", "success" if success else "failure", f"ECHOPORT_RESULT:{json.dumps(result)}")


def finish_stdout(status: str, message: str = "") -> None:
    payload = {"event": "finish", "status": status}
    if message:
        payload["message"] = message
    _emit(payload)


def safe_error(exc: Exception) -> str:
    if isinstance(exc, subprocess.CalledProcessError):
        stderr = (exc.stderr or "").strip()
        stdout = (exc.stdout or "").strip()
        if stderr:
            return stderr
        if stdout:
            return stdout
        return f"Command failed with exit code {exc.returncode}"
    return str(exc)


def run_cmd(args: list[str], check: bool = True) -> subprocess.CompletedProcess:
    result = subprocess.run(args, capture_output=True, text=True)
    if check and result.returncode != 0:
        raise subprocess.CalledProcessError(result.returncode, args, result.stdout, result.stderr)
    return result


def calculate_sha256(filepath: Path) -> str:
    sha256_hash = hashlib.sha256()
    with open(filepath, "rb") as handle:
        for chunk in iter(lambda: handle.read(8192), b""):
            sha256_hash.update(chunk)
    return sha256_hash.hexdigest()


def normalize_root(root: str) -> str:
    normalized = os.path.realpath(root)
    if not normalized.endswith(os.sep):
        normalized += os.sep
    return normalized


def path_in_allowed_roots(path: str) -> bool:
    if not path:
        return False
    resolved = os.path.realpath(path)
    for root in ALLOWED_ROOTS:
        normalized_root = normalize_root(root)
        if resolved.startswith(normalized_root) or resolved == normalized_root.rstrip(os.sep):
            return True
    return False


def validate_config_paths() -> None:
    configured_paths = [
        DATA_DIR,
        # DB_DIR is validated as part of the contract even though restore skips DATA_DIR/db/*
        # (MongoDB data lives under mongod's dbPath, typically /var/lib/mongodb).
        DB_DIR,
        SYSTEM_PROPERTIES,
        KEYSTORE_PATH,
        ENV_FILE,
        SYSTEMD_UNIT,
        TRAEFIK_CONFIG,
        MONGO_CREDENTIALS_FILE,
        TEMP_DIR,
    ]
    for cfg_path in configured_paths:
        if cfg_path and not path_in_allowed_roots(cfg_path):
            raise ValueError(f"Configured path outside allowed roots: {cfg_path}")

    if not Path(DATA_DIR).is_dir():
        raise FileNotFoundError(f"UniFi data directory missing: {DATA_DIR}")
    if not Path(DB_DIR).is_dir():
        raise FileNotFoundError(f"UniFi DB directory missing: {DB_DIR}")
    if not Path(SYSTEM_PROPERTIES).is_file():
        raise FileNotFoundError(f"system.properties missing: {SYSTEM_PROPERTIES}")
    if not Path(MONGO_CREDENTIALS_FILE).is_file():
        raise FileNotFoundError(f"Mongo credentials file missing: {MONGO_CREDENTIALS_FILE}")


def ensure_binaries() -> None:
    needed = [
        MC_PATH,
        "mongodump",
        "mongorestore",
        "mongosh",
        "rsync",
        "tar",
        "systemctl",
        "chown",
        "sha256sum",
    ]
    for binary in needed:
        if binary.startswith("/"):
            if not Path(binary).exists():
                raise FileNotFoundError(f"Required binary not found: {binary}")
        else:
            result = run_cmd(["which", binary], check=False)
            if result.returncode != 0:
                raise FileNotFoundError(f"Required binary not found in PATH: {binary}")


def read_mongo_credentials() -> Dict[str, str]:
    with open(MONGO_CREDENTIALS_FILE, "r") as handle:
        creds = json.load(handle)

    required = ["host", "port", "database", "username", "password", "auth_db"]
    missing = [key for key in required if key not in creds or str(creds[key]).strip() == ""]
    if missing:
        raise RuntimeError(f"Mongo credentials file missing required keys: {', '.join(missing)}")

    return {
        "host": str(creds["host"]),
        "port": str(creds["port"]),
        "database": str(creds["database"]),
        "username": str(creds["username"]),
        "password": str(creds["password"]),
        "auth_db": str(creds["auth_db"]),
    }


def service_is_active() -> bool:
    result = run_cmd(["systemctl", "is-active", SERVICE_NAME], check=False)
    return result.stdout.strip() == "active"


def rsync_dir(src: Path, dst: Path, delete: bool = True, excludes: list[str] | None = None) -> None:
    if not src.exists() or not src.is_dir():
        return
    dst.mkdir(parents=True, exist_ok=True)
    args = ["rsync", "-a"]
    if delete:
        args.append("--delete")
    for item in excludes or []:
        args.extend(["--exclude", item])
    args.extend([f"{src}/", f"{dst}/"])
    run_cmd(args)


def copy_file_optional(src: Path, dst: Path) -> bool:
    if not src.exists() or not src.is_file():
        return False
    dst.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(src, dst)
    return True


def apply_ownership(path: Path) -> None:
    if path.exists():
        run_cmd(["chown", "-R", f"{UNIFI_OWNER}:{UNIFI_GROUP}", str(path)])


def create_tarball(source_dir: Path, tarball_path: Path) -> None:
    with tarfile.open(tarball_path, "w:gz") as tar:
        for item in sorted(source_dir.iterdir(), key=lambda p: p.name):
            tar.add(item, arcname=item.name)


def get_tree_size(path: Path) -> int:
    if not path.exists():
        return 0
    if path.is_file():
        return path.stat().st_size
    total = 0
    for entry in path.rglob("*"):
        try:
            if entry.is_file():
                total += entry.stat().st_size
        except Exception:
            continue
    return total


def get_free_bytes_for_path(path: Path) -> int:
    candidate = path
    while not candidate.exists() and candidate != candidate.parent:
        candidate = candidate.parent
    stat = os.statvfs(candidate)
    return stat.f_bavail * stat.f_frsize


def disk_space_precheck(tarball_path: Path, temp_root: Path) -> None:
    with tarfile.open(tarball_path, "r:gz") as tar:
        extracted_payload_size = sum(member.size for member in tar.getmembers())
    current_data_size = get_tree_size(Path(DATA_DIR))

    required_temp = int(extracted_payload_size * 1.20)
    required_data = int(max(current_data_size, extracted_payload_size) * 1.10)
    free_temp = get_free_bytes_for_path(temp_root)
    free_data = get_free_bytes_for_path(Path(DATA_DIR))

    if free_temp < required_temp:
        raise RuntimeError(
            f"Insufficient temp disk space for restore: required={required_temp} free={free_temp}"
        )
    if free_data < required_data:
        raise RuntimeError(
            f"Insufficient data disk space for restore: required={required_data} free={free_data}"
        )


def _is_safe_tar_member(member: tarfile.TarInfo, extract_dir: Path) -> tuple[bool, str]:
    if member.isdev() or member.ischr() or member.isblk():
        return False, f"Tarball contains device node: {member.name}"
    if member.isfifo():
        return False, f"Tarball contains FIFO: {member.name}"
    if member.name.startswith("/"):
        return False, f"Tarball contains absolute path: {member.name}"
    if ".." in member.name:
        return False, f"Tarball contains path traversal: {member.name}"

    target_path = (extract_dir / member.name).resolve()
    try:
        target_path.relative_to(extract_dir.resolve())
    except ValueError:
        return False, f"Tarball member escapes extraction root: {member.name}"

    return True, ""


def safe_extract_tarball(tarball_path: Path, extract_dir: Path) -> None:
    with tarfile.open(tarball_path, "r:gz") as tar:
        safe_members = []
        for member in tar.getmembers():
            is_safe, err = _is_safe_tar_member(member, extract_dir)
            if not is_safe:
                raise ValueError(err)
            safe_members.append(member)
        tar.extractall(extract_dir, members=safe_members)


def make_checksum_manifest(root_dir: Path, manifest_path: Path) -> None:
    entries: list[Path] = []
    for path in root_dir.rglob("*"):
        if not path.is_file():
            continue
        if path.resolve() == manifest_path.resolve():
            continue
        entries.append(path)
    entries.sort(key=lambda p: p.relative_to(root_dir).as_posix())

    lines: list[str] = []
    for item in entries:
        rel = item.relative_to(root_dir).as_posix()
        lines.append(f"{calculate_sha256(item)}  ./{rel}")
    manifest_path.write_text("\n".join(lines) + ("\n" if lines else ""))


def verify_checksum_manifest(root_dir: Path, manifest_path: Path) -> None:
    if not manifest_path.exists():
        raise FileNotFoundError("manifest.sha256 missing from backup archive")

    lines = [line.strip() for line in manifest_path.read_text().splitlines() if line.strip()]
    for line in lines:
        parts = line.split("  ", 1)
        if len(parts) != 2:
            raise ValueError(f"Invalid checksum manifest line: {line}")
        expected, rel_path = parts
        clean_rel = rel_path[2:] if rel_path.startswith("./") else rel_path
        target = root_dir / clean_rel
        if not target.exists() or not target.is_file():
            raise FileNotFoundError(f"Checksum target missing: {clean_rel}")
        actual = calculate_sha256(target)
        if actual != expected:
            raise ValueError(f"Checksum mismatch for {clean_rel}: expected {expected}, got {actual}")


def upload_to_minio(tarball_path: Path, bucket: str, key: str) -> None:
    run_cmd([MC_PATH, "cp", str(tarball_path), f"{MINIO_ALIAS}/{bucket}/{key}"])


def download_from_minio(bucket: str, key: str, dest_path: Path) -> None:
    run_cmd([MC_PATH, "cp", f"{MINIO_ALIAS}/{bucket}/{key}", str(dest_path)])
    if not dest_path.exists():
        raise RuntimeError(f"Download failed, file missing at {dest_path}")


def mongo_dump(creds: Dict[str, str], output_dir: Path) -> None:
    args = [
        "mongodump",
        f"--host={creds['host']}",
        f"--port={creds['port']}",
        f"--db={creds['database']}",
        f"--out={output_dir}",
        f"--username={creds['username']}",
        f"--password={creds['password']}",
        f"--authenticationDatabase={creds['auth_db']}",
    ]
    run_cmd(args)
    if not (output_dir / creds["database"]).is_dir():
        raise RuntimeError("mongodump completed but dump directory missing")


def mongo_drop_database(creds: Dict[str, str]) -> None:
    args = [
        "mongosh",
        f"--host={creds['host']}",
        f"--port={creds['port']}",
        "--quiet",
        f"--username={creds['username']}",
        f"--password={creds['password']}",
        f"--authenticationDatabase={creds['auth_db']}",
        creds["database"],
        "--eval=db.dropDatabase()",
    ]
    run_cmd(args)


def mongo_restore(creds: Dict[str, str], dump_dir: Path) -> None:
    args = [
        "mongorestore",
        f"--host={creds['host']}",
        f"--port={creds['port']}",
        f"--db={creds['database']}",
        f"--dir={dump_dir}",
        f"--username={creds['username']}",
        f"--password={creds['password']}",
        f"--authenticationDatabase={creds['auth_db']}",
    ]
    run_cmd(args)


def mongo_dump_check(creds: Dict[str, str]) -> None:
    args = [
        "mongodump",
        f"--host={creds['host']}",
        f"--port={creds['port']}",
        f"--db={creds['database']}",
        "--archive=/dev/null",
        "--gzip",
        f"--username={creds['username']}",
        f"--password={creds['password']}",
        f"--authenticationDatabase={creds['auth_db']}",
    ]
    run_cmd(args)


def wait_service_active(timeout_seconds: int = START_TIMEOUT) -> None:
    deadline = time.time() + timeout_seconds
    while time.time() < deadline:
        result = run_cmd(["systemctl", "is-active", SERVICE_NAME], check=False)
        if result.stdout.strip() == "active":
            return
        time.sleep(2)
    raise RuntimeError(f"Service did not become active in {timeout_seconds}s: {SERVICE_NAME}")


def wait_tcp_port(host: str, port: int, timeout_seconds: int = START_TIMEOUT) -> None:
    deadline = time.time() + timeout_seconds
    while time.time() < deadline:
        result = run_cmd(["sh", "-lc", f"nc -z {host} {port}"], check=False)
        if result.returncode == 0:
            return
        time.sleep(2)
    raise RuntimeError(f"{host}:{port} did not become reachable in {timeout_seconds}s")


def run_health_check() -> None:
    # UniFi uses a self-signed certificate on loopback health endpoint.
    # TLS verification is intentionally disabled for this local check.
    ctx = ssl._create_unverified_context()
    for attempt in range(1, HEALTH_RETRIES + 1):
        try:
            req = Request(HEALTH_URL, method="GET")
            with urlopen(req, timeout=10, context=ctx) as resp:
                if resp.status in (200, 302, 303):
                    return
        except URLError:
            pass
        except Exception:
            pass

        if attempt < HEALTH_RETRIES:
            time.sleep(HEALTH_DELAY)
    raise RuntimeError(f"Health check failed: {HEALTH_URL}")


def backup_flow(cenv: Dict) -> int:
    emit_step("init", "running", "Validating backup configuration")
    target_name = cenv.get("ECHOPORT_TARGET", "unifi")
    run_id = cenv.get("ECHOPORT_RUN_ID", "0")
    bucket = cenv.get("ECHOPORT_BUCKET", DEFAULT_BUCKET)
    key_prefix = cenv.get(
        "ECHOPORT_KEY_PREFIX",
        f"{target_name}/{datetime.now(timezone.utc).strftime('%Y-%m-%dT%H-%M-%S')}",
    )

    validate_config_paths()
    ensure_binaries()
    creds = read_mongo_credentials()
    emit_step("init", "success", f"Configuration loaded for {target_name} run {run_id}")

    parent = TEMP_DIR if Path(TEMP_DIR).exists() else None
    work_dir = Path(tempfile.mkdtemp(prefix="unifi_backup_", dir=parent))
    service_stopped = False
    was_active = service_is_active()

    try:
        payload = work_dir / "payload"
        db_out = payload / "database"
        data_out = payload / "data"
        config_out = payload / "config"
        system_out = payload / "system"
        db_out.mkdir(parents=True, exist_ok=True)
        data_out.mkdir(parents=True, exist_ok=True)
        config_out.mkdir(parents=True, exist_ok=True)
        system_out.mkdir(parents=True, exist_ok=True)

        emit_step("backup_db", "running", "Dumping UniFi MongoDB")
        mongo_dump(creds, db_out)
        emit_step("backup_db", "success", "MongoDB dump completed")

        if was_active:
            emit_step("stop_service", "running", f"Stopping {SERVICE_NAME}")
            run_cmd(["systemctl", "stop", SERVICE_NAME])
            service_stopped = True
            emit_step("stop_service", "success", f"Stopped {SERVICE_NAME}")
        else:
            emit_step("stop_service", "success", "Service not active, stop skipped")

        emit_step("copy_data", "running", "Copying UniFi data directory")
        rsync_dir(Path(DATA_DIR), data_out, delete=True, excludes=["db/*"])
        emit_step("copy_data", "success", "Data directory copied")

        emit_step("copy_config", "running", "Copying config/system files")
        copy_file_optional(Path(SYSTEM_PROPERTIES), config_out / "system.properties")
        copy_file_optional(Path(KEYSTORE_PATH), config_out / "keystore")
        copy_file_optional(Path(ENV_FILE), config_out / "unifi.env")
        copy_file_optional(Path(SYSTEMD_UNIT), system_out / "unifi.service")
        copy_file_optional(Path(TRAEFIK_CONFIG), system_out / "unifi.yml")
        emit_step("copy_config", "success", "Config/system files copied")

        if was_active and service_stopped:
            emit_step("start_service", "running", f"Starting {SERVICE_NAME}")
            run_cmd(["systemctl", "start", SERVICE_NAME])
            wait_service_active(START_TIMEOUT)
            service_stopped = False
            emit_step("start_service", "success", f"Started {SERVICE_NAME}")
        else:
            emit_step("start_service", "success", "Service start unchanged")

        manifest = {
            "target": target_name,
            "run_id": run_id,
            "generated_at": datetime.now(timezone.utc).isoformat(),
            "service": SERVICE_NAME,
            "service_active_during_backup": was_active,
            "mongo_database": creds["database"],
            "paths": {
                "data_dir": DATA_DIR,
                "db_dir": DB_DIR,
                "system_properties": SYSTEM_PROPERTIES,
                "keystore_path": KEYSTORE_PATH,
                "env_file": ENV_FILE,
                "systemd_unit": SYSTEMD_UNIT,
                "traefik_config": TRAEFIK_CONFIG,
            },
        }
        (payload / "manifest.json").write_text(json.dumps(manifest, indent=2))
        make_checksum_manifest(payload, payload / "manifest.sha256")

        emit_step("upload", "running", "Creating archive and uploading")
        tarball_path = work_dir / "backup.tar.gz"
        create_tarball(payload, tarball_path)
        checksum = calculate_sha256(tarball_path)
        storage_key = f"{key_prefix}.tar.gz"
        upload_to_minio(tarball_path, bucket, storage_key)
        emit_step("upload", "success", f"Uploaded {storage_key}")

        emit_step("verify", "running", "Verifying object in MinIO")
        run_cmd([MC_PATH, "stat", f"{MINIO_ALIAS}/{bucket}/{storage_key}"])
        emit_step("verify", "success", "MinIO object verified")

        file_count = sum(1 for p in payload.rglob("*") if p.is_file())
        emit_result(
            success=True,
            bucket=bucket,
            key=storage_key,
            size_bytes=tarball_path.stat().st_size,
            checksum_sha256=checksum,
            file_count=file_count,
        )
        finish_stdout("success", f"Backup completed: {storage_key}")
        return 0
    except Exception as exc:
        msg = safe_error(exc)
        emit_step("error", "failure", msg)
        emit_result(False, error=msg)
        finish_stdout("failure", f"Backup failed: {msg}")
        return 1
    finally:
        if service_stopped:
            try:
                run_cmd(["systemctl", "start", SERVICE_NAME], check=False)
            except Exception:
                pass
        shutil.rmtree(work_dir, ignore_errors=True)


def restore_flow(cenv: Dict) -> int:
    emit_step("init", "running", "Validating restore configuration")
    target_name = cenv.get("ECHOPORT_TARGET", "unifi")
    restore_id = cenv.get("ECHOPORT_RESTORE_ID", "0")
    bucket = cenv.get("ECHOPORT_BUCKET", DEFAULT_BUCKET)
    storage_key = cenv.get("ECHOPORT_KEY", "")
    expected_checksum = cenv.get("ECHOPORT_CHECKSUM", "")

    if not storage_key:
        raise RuntimeError("ECHOPORT_KEY missing for restore")
    if not expected_checksum:
        raise RuntimeError("ECHOPORT_CHECKSUM missing for restore")

    validate_config_paths()
    ensure_binaries()
    creds = read_mongo_credentials()
    emit_step("init", "success", f"Configuration loaded for {target_name} restore {restore_id}")

    parent = TEMP_DIR if Path(TEMP_DIR).exists() else None
    work_dir = Path(tempfile.mkdtemp(prefix="unifi_restore_", dir=parent))
    service_stopped = False
    destructive_started = False
    safety_snapshot_dir = work_dir / "safety_db"

    try:
        tarball_path = work_dir / "backup.tar.gz"
        extract_dir = work_dir / "extract"
        extract_dir.mkdir(parents=True, exist_ok=True)

        emit_step("download", "running", "Downloading archive from MinIO")
        download_from_minio(bucket, storage_key, tarball_path)
        emit_step("download", "success", f"Downloaded {storage_key}")

        emit_step("verify_checksum", "running", "Verifying archive checksum")
        actual_checksum = calculate_sha256(tarball_path)
        if actual_checksum != expected_checksum:
            raise RuntimeError(f"Checksum mismatch: expected {expected_checksum}, got {actual_checksum}")
        emit_step("verify_checksum", "success", "Archive checksum verified")

        emit_step("precheck", "running", "Validating available disk space")
        disk_space_precheck(tarball_path, work_dir)
        emit_step("precheck", "success", "Disk space precheck passed")

        emit_step("extract", "running", "Extracting archive")
        safe_extract_tarball(tarball_path, extract_dir)
        verify_checksum_manifest(extract_dir, extract_dir / "manifest.sha256")
        emit_step("extract", "success", "Archive extracted and validated")

        emit_step("stop_service", "running", f"Stopping {SERVICE_NAME}")
        if service_is_active():
            run_cmd(["systemctl", "stop", SERVICE_NAME])
            service_stopped = True
            emit_step("stop_service", "success", f"Stopped {SERVICE_NAME}")
        else:
            emit_step("stop_service", "success", "Service not active, stop skipped")

        emit_step("safety_snapshot", "running", "Creating pre-restore MongoDB safety snapshot")
        mongo_dump(creds, safety_snapshot_dir)
        emit_step("safety_snapshot", "success", "MongoDB safety snapshot created")

        emit_step("restore_db", "running", "Restoring MongoDB")
        dump_dir = extract_dir / "database" / creds["database"]
        if not dump_dir.exists():
            raise RuntimeError(f"Archive missing MongoDB dump directory: {dump_dir}")
        destructive_started = True
        mongo_drop_database(creds)
        mongo_restore(creds, dump_dir)
        emit_step("restore_db", "success", "MongoDB restored")

        emit_step("restore_data", "running", "Restoring UniFi data directory")
        # Keep DATA_DIR/db untouched during restore; MongoDB data is restored via mongorestore.
        rsync_dir(extract_dir / "data", Path(DATA_DIR), delete=True, excludes=["db/*"])
        emit_step("restore_data", "success", "Data directory restored")

        emit_step("restore_config", "running", "Restoring config/system files")
        copy_file_optional(extract_dir / "config" / "system.properties", Path(SYSTEM_PROPERTIES))
        copy_file_optional(extract_dir / "config" / "keystore", Path(KEYSTORE_PATH))
        if copy_file_optional(extract_dir / "config" / "unifi.env", Path(ENV_FILE)):
            run_cmd(["chmod", "0640", ENV_FILE])
        if copy_file_optional(extract_dir / "system" / "unifi.service", Path(SYSTEMD_UNIT)):
            run_cmd(["chmod", "0644", SYSTEMD_UNIT])
        if copy_file_optional(extract_dir / "system" / "unifi.yml", Path(TRAEFIK_CONFIG)):
            run_cmd(["chmod", "0644", TRAEFIK_CONFIG])
        apply_ownership(Path(DATA_DIR))
        run_cmd(["systemctl", "daemon-reload"])
        emit_step("restore_config", "success", "Config/system files restored")

        emit_step("start_service", "running", f"Starting {SERVICE_NAME}")
        run_cmd(["systemctl", "start", SERVICE_NAME])
        wait_service_active(START_TIMEOUT)
        service_stopped = False
        emit_step("start_service", "success", f"Started {SERVICE_NAME}")

        emit_step("health_check", "running", "Running service health checks")
        wait_tcp_port(creds["host"], int(creds["port"]), START_TIMEOUT)
        mongo_dump_check(creds)
        run_health_check()
        emit_step("health_check", "success", "Service health checks passed")
        emit_step("rollback", "success", "Rollback not required")

        file_count = sum(1 for p in extract_dir.rglob("*") if p.is_file())
        emit_result(
            success=True,
            bucket=bucket,
            key=storage_key,
            size_bytes=tarball_path.stat().st_size,
            checksum_sha256=actual_checksum,
            file_count=file_count,
        )
        finish_stdout("success", "Restore completed")
        return 0
    except Exception as exc:
        msg = safe_error(exc)
        rollback_error = ""
        rollback_executed = False
        if destructive_started and safety_snapshot_dir.exists():
            emit_step("rollback", "running", "Restore failed; attempting MongoDB rollback from safety snapshot")
            try:
                snapshot_dump_dir = safety_snapshot_dir / creds["database"]
                if not snapshot_dump_dir.exists():
                    raise RuntimeError(f"Safety snapshot dump missing: {snapshot_dump_dir}")
                mongo_drop_database(creds)
                mongo_restore(creds, snapshot_dump_dir)
                rollback_executed = True
                emit_step("rollback", "success", "MongoDB rollback completed")
            except Exception as rollback_exc:
                rollback_error = safe_error(rollback_exc)
                emit_step("rollback", "failure", f"MongoDB rollback failed: {rollback_error}")
        else:
            emit_step("rollback", "success", "Rollback not required")
        if service_stopped:
            try:
                run_cmd(["systemctl", "start", SERVICE_NAME], check=False)
            except Exception:
                pass
        if rollback_executed:
            msg = f"{msg} (rollback executed)"
        if rollback_error:
            msg = f"{msg}; rollback failed: {rollback_error}"
        emit_step("error", "failure", msg)
        emit_result(False, error=msg)
        finish_stdout("failure", f"Restore failed: {msg}")
        return 1
    finally:
        shutil.rmtree(work_dir, ignore_errors=True)


def main() -> int:
    config = read_config_file()

    if config:
        context = config.get("context", {})
    else:
        if os.getuid() == 0:
            raise RuntimeError("No config file found while running as root")
        context_raw = os.environ.get("CONTEXT", "{}")
        context = json.loads(context_raw)

    cenv = context.get("env", {})
    action = cenv.get("ECHOPORT_ACTION", "backup")

    if action == "restore":
        return restore_flow(cenv)
    return backup_flow(cenv)


if __name__ == "__main__":
    if os.getuid() != 0:
        script_path = os.path.abspath(__file__)
        result = subprocess.run(
            ["sudo", "-n", script_path] + sys.argv[1:],
            stdout=sys.stdout,
            stderr=sys.stderr,
        )
        sys.exit(result.returncode)

    Path(TEMP_DIR).mkdir(parents=True, exist_ok=True)

    try:
        sys.exit(main())
    except Exception as exc:
        msg = safe_error(exc)
        emit_step("error", "failure", msg)
        emit_result(False, error=msg)
        finish_stdout("failure", f"Unexpected error: {msg}")
        sys.exit(1)
