[Unit]
Description=Logyard Loki (Docker Compose)
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory={{ logyard_home }}
ExecStart=/usr/bin/docker compose -f {{ logyard_compose_path }} up -d --remove-orphans
ExecStop=/usr/bin/docker compose -f {{ logyard_compose_path }} down
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target
