use('{{ unifi_mongodb_database }}');
var existing = db.admin.findOne({name: "{{ unifi_homeassistant_username }}"});
var changed = false;
var now = Date.now();

if (!existing) {
  db.admin.insertOne({
    "email": "{{ unifi_homeassistant_username }}@local",
    "name": "{{ unifi_homeassistant_username }}",
    "last_site_name": "default",
    "time_created": NumberLong(now.toString()),
    "x_shadow": "{{ unifi_homeassistant_password_hash.stdout | trim }}"
  });
  changed = true;
} else if (existing.x_shadow !== "{{ unifi_homeassistant_password_hash.stdout | trim }}") {
  db.admin.updateOne(
    {"_id": existing._id},
    {
      "$set": {
        "email": existing.email || "{{ unifi_homeassistant_username }}@local",
        "last_site_name": existing.last_site_name || "default",
        "x_shadow": "{{ unifi_homeassistant_password_hash.stdout | trim }}"
      }
    }
  );
  changed = true;
}

var haUser = db.admin.findOne({name: "{{ unifi_homeassistant_username }}"});
var defaultSite = db.site.findOne({name: "default"});

if (haUser && defaultSite) {
  var existingPrivilege = db.privilege.findOne({
    "admin_id": haUser._id,
    "site_id": defaultSite._id
  });
  if (!existingPrivilege) {
    db.privilege.insertOne({
      "admin_id": haUser._id,
      "site_id": defaultSite._id,
      "role": "readonly",
      "permissions": []
    });
    changed = true;
  } else if (existingPrivilege.role !== "readonly") {
    db.privilege.updateOne(
      {"_id": existingPrivilege._id},
      {"$set": {"role": "readonly", "permissions": []}}
    );
    changed = true;
  }
} else {
  print("STATUS=error missing_unifi_user_or_site");
}

print("STATUS=ok changed=" + changed);
