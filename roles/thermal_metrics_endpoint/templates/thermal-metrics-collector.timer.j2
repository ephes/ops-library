[Unit]
Description=Collect thermal metrics every {{ thermal_metrics_endpoint_timer_interval }} seconds

[Timer]
OnBootSec={{ thermal_metrics_endpoint_timer_on_boot_sec }}
OnUnitActiveSec={{ thermal_metrics_endpoint_timer_interval }}
AccuracySec={{ thermal_metrics_endpoint_timer_accuracy_sec }}
RandomizedDelaySec={{ thermal_metrics_endpoint_timer_randomized_delay_sec }}
Persistent=true

[Install]
WantedBy=timers.target
