[Unit]
Description=Collect thermal metrics and write to JSON file
After=network.target

[Service]
Type=oneshot
ExecStart=/bin/bash -c '{{ thermal_metrics_endpoint_exporter_path }} > {{ thermal_metrics_endpoint_json_path }}.tmp && mv {{ thermal_metrics_endpoint_json_path }}.tmp {{ thermal_metrics_endpoint_json_path }}'

User=root
Group=root

ExecStartPre=/bin/mkdir -p {{ thermal_metrics_endpoint_data_dir }}
ExecStartPre=/bin/chown root:{{ thermal_metrics_endpoint_group }} {{ thermal_metrics_endpoint_data_dir }}
ExecStartPre=/bin/chmod 0750 {{ thermal_metrics_endpoint_data_dir }}

ExecStartPost=/bin/chown root:{{ thermal_metrics_endpoint_group }} {{ thermal_metrics_endpoint_json_path }}
ExecStartPost=/bin/chmod 0640 {{ thermal_metrics_endpoint_json_path }}
