<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>{{ daybook_archive_quote_classifier_launchd_label | e }}</string>
  <key>ProgramArguments</key>
  <array>
    <string>{{ daybook_archive_quote_classifier_launcher_path | e }}</string>
  </array>
  <key>WorkingDirectory</key>
  <string>{{ daybook_sessions_checkout_path | e }}</string>
  <key>ProcessType</key>
  <string>Background</string>
  <key>LowPriorityIO</key>
  <true/>
{% if not (daybook_archive_browser_headless | bool) %}
  <key>LimitLoadToSessionType</key>
  <string>Aqua</string>
{% endif %}
  <key>ThrottleInterval</key>
  <integer>{{ daybook_archive_quote_classifier_throttle_interval_seconds | int }}</integer>
{% if daybook_archive_quote_classifier_run_at_load | bool %}
  <key>RunAtLoad</key>
  <true/>
{% endif %}
  <key>StartCalendarInterval</key>
  <array>
{% for schedule in daybook_archive_quote_classifier_start_calendar %}
    <dict>
      <key>Hour</key>
      <integer>{{ schedule.Hour | int }}</integer>
      <key>Minute</key>
      <integer>{{ schedule.Minute | int }}</integer>
    </dict>
{% endfor %}
  </array>
  <key>StandardOutPath</key>
  <string>{{ daybook_archive_quote_classifier_stdout_log | e }}</string>
  <key>StandardErrorPath</key>
  <string>{{ daybook_archive_quote_classifier_stderr_log | e }}</string>
{% if daybook_sessions_launchd_scope == 'system' %}
  <key>UserName</key>
  <string>{{ daybook_sessions_service_user | e }}</string>
  <key>GroupName</key>
  <string>{{ daybook_sessions_service_group | e }}</string>
{% endif %}
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>{{ daybook_sessions_launchd_path | e }}</string>
    <key>HOME</key>
    <string>{{ daybook_sessions_service_home | e }}</string>
    <key>USER</key>
    <string>{{ daybook_sessions_service_user | e }}</string>
    <key>LOGNAME</key>
    <string>{{ daybook_sessions_service_user | e }}</string>
    <key>XDG_CONFIG_HOME</key>
    <string>{{ (daybook_sessions_service_home ~ '/.config') | e }}</string>
    <key>XDG_CACHE_HOME</key>
    <string>{{ (daybook_sessions_service_home ~ '/.cache') | e }}</string>
    <key>XDG_DATA_HOME</key>
    <string>{{ (daybook_sessions_service_home ~ '/.local/share') | e }}</string>
    <key>UV_PROJECT_ENVIRONMENT</key>
    <string>{{ (daybook_sessions_checkout_path ~ '/.venv') | e }}</string>
  </dict>
</dict>
</plist>
