# Managed by Ansible (graphyard_deploy role). Do not edit manually.
{% set allowed_hosts = graphyard_django_allowed_hosts if graphyard_django_allowed_hosts is string else (graphyard_django_allowed_hosts | join(',')) %}
{% set csrf_origins = graphyard_django_csrf_trusted_origins if graphyard_django_csrf_trusted_origins is string else (graphyard_django_csrf_trusted_origins | join(',')) %}
DJANGO_SETTINGS_MODULE={{ graphyard_django_settings_module }}
DJANGO_SECRET_KEY={{ graphyard_django_secret_key }}
DJANGO_ALLOWED_HOSTS={{ allowed_hosts }}
DJANGO_CSRF_TRUSTED_ORIGINS={{ csrf_origins }}
DJANGO_ADMIN_URL={{ graphyard_django_admin_url }}
DJANGO_LOGIN_URL={{ graphyard_django_login_url }}
DJANGO_LOGIN_REDIRECT_URL={{ graphyard_django_login_redirect_url }}
DJANGO_SESSION_COOKIE_AGE_SECONDS={{ graphyard_django_session_cookie_age_seconds }}

INFLUX_URL={{ graphyard_influx_url }}
INFLUX_TOKEN={{ graphyard_influx_token }}
INFLUX_ORG={{ graphyard_influx_org }}
INFLUX_BUCKET={{ graphyard_influx_bucket }}
INFLUX_MEASUREMENT={{ graphyard_influx_measurement }}
INFLUX_TIMEOUT_MS={{ graphyard_influx_timeout_ms }}
INFLUX_API_MODE={{ graphyard_influx_api_mode }}

GRAFANA_BASE_URL={{ graphyard_grafana_base_url }}

GRAPHYARD_METRIC_COLLECTION_INTERVAL_SECONDS={{ graphyard_metric_collection_interval_seconds }}
GRAPHYARD_CONDITION_EVAL_INTERVAL_SECONDS={{ graphyard_condition_eval_interval_seconds }}
GRAPHYARD_INGEST_HEARTBEAT_MIN_INTERVAL_SECONDS={{ graphyard_ingest_heartbeat_min_interval_seconds }}

GRAPHYARD_HEARTBEAT_WARNING_SECONDS={{ graphyard_heartbeat_warning_seconds }}
GRAPHYARD_HEARTBEAT_CRITICAL_SECONDS={{ graphyard_heartbeat_critical_seconds }}
GRAPHYARD_CONDITION_DATA_STALE_WARNING_SECONDS={{ graphyard_condition_data_stale_warning_seconds }}

GRAPHYARD_SQLITE_TIMEOUT_SECONDS={{ graphyard_sqlite_timeout_seconds }}
GRAPHYARD_SQLITE_BUSY_TIMEOUT_MS={{ graphyard_sqlite_busy_timeout_ms }}
GRAPHYARD_SQLITE_JOURNAL_MODE={{ graphyard_sqlite_journal_mode }}
GRAPHYARD_SQLITE_SYNCHRONOUS={{ graphyard_sqlite_synchronous }}
