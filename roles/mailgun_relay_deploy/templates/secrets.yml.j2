# Managed by Ansible (mailgun_relay_deploy role). Do not edit manually.
# Secret token verifiers (sha256 hex of the raw token, NEVER the token itself)
# plus authenticated SMTP submission credentials.
smtp:
  username: "{{ mailgun_relay_smtp_username }}"
  password: "{{ mailgun_relay_smtp_password }}"

tokens:
{% for token in mailgun_relay_tokens %}
  - label: "{{ token.label }}"
    token_sha256: "{{ token.token_sha256 }}"
    mailgun_domains:
{% for d in token.mailgun_domains %}
      - "{{ d }}"
{% endfor %}
    allowed_from_domains:
{% for d in token.allowed_from_domains %}
      - "{{ d }}"
{% endfor %}
{% if token.allowed_from_addresses is defined and token.allowed_from_addresses | length > 0 %}
    allowed_from_addresses:
{% for a in token.allowed_from_addresses %}
      - "{{ a }}"
{% endfor %}
{% endif %}
{% endfor %}
