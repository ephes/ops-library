CHESSLAB_DB_PATH={{ chesslab_db_path }}
CHESSLAB_OWNER={{ chesslab_owner }}
{% if chesslab_users | length > 0 %}
CHESSLAB_USERS_JSON={{ (chesslab_users | to_json) | to_json }}
{% else %}
CHESSLAB_LOGIN_USER={{ chesslab_login_user }}
CHESSLAB_LOGIN_PASSWORD={{ chesslab_login_password }}
{% endif %}
CHESSLAB_SESSION_SECRET={{ chesslab_session_secret }}
{% if chesslab_limit | string | length > 0 %}
CHESSLAB_LIMIT={{ chesslab_limit }}
{% endif %}
