[Unit]
Description=Collect Tailscale login and key-expiry metrics
After=tailscaled.service network-online.target
Wants=tailscaled.service network-online.target

[Service]
Type=oneshot
ExecStart=/bin/bash -c '{{ tailscale_metrics_endpoint_exporter_path }} > {{ tailscale_metrics_endpoint_json_path }}.tmp && mv {{ tailscale_metrics_endpoint_json_path }}.tmp {{ tailscale_metrics_endpoint_json_path }}'

User=root
Group=root

ExecStartPre=/bin/mkdir -p {{ tailscale_metrics_endpoint_data_dir }}
ExecStartPre=/bin/chown root:{{ tailscale_metrics_endpoint_group }} {{ tailscale_metrics_endpoint_data_dir }}
ExecStartPre=/bin/chmod 0750 {{ tailscale_metrics_endpoint_data_dir }}

ExecStartPost=/bin/chown root:{{ tailscale_metrics_endpoint_group }} {{ tailscale_metrics_endpoint_json_path }}
ExecStartPost=/bin/chmod 0640 {{ tailscale_metrics_endpoint_json_path }}
